/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Permissions-Policy: camera=(), microphone=(self), geolocation=(), payment=(), interest-cohort=()
  X-Robots-Tag: index, follow, max-image-preview:large
  # 'unsafe-eval' required by Retell widget runtime (non-negotiable dependency of dashboard.retellai.com/retell-widget.js).
  # Revisit if Retell ships an eval-free build or we migrate to CSP nonces.
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://dashboard.retellai.com https://www.googletagmanager.com https://www.google-analytics.com https://tagmanager.google.com; script-src-elem 'self' 'unsafe-inline' https://dashboard.retellai.com https://www.googletagmanager.com https://www.google-analytics.com https://tagmanager.google.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.jsdelivr.net; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https://luxeshutters.com.au https://www.google-analytics.com https://www.googletagmanager.com https://dashboard.retellai.com https://*.retellai.com; connect-src 'self' https://www.google-analytics.com https://region1.google-analytics.com https://www.googletagmanager.com https://dashboard.retellai.com https://*.retellai.com wss://*.retellai.com https://primary-production-5fdce.up.railway.app; frame-src https://www.google.com https://maps.google.com https://dashboard.retellai.com; worker-src 'self' blob:; media-src 'self' blob: https://*.retellai.com; base-uri 'self'; form-action 'self'; object-src 'none'; frame-ancestors 'none'; upgrade-insecure-requests

/assets/*
  Cache-Control: public, max-age=31536000, immutable
  ! Content-Security-Policy

/*.webp
  Cache-Control: public, max-age=31536000, immutable

/*.svg
  Cache-Control: public, max-age=31536000, immutable

/*.png
  Cache-Control: public, max-age=31536000, immutable

/*.ico
  Cache-Control: public, max-age=31536000, immutable

/site.webmanifest
  Cache-Control: public, max-age=604800
  Content-Type: application/manifest+json

/sitemap.xml
  Cache-Control: public, max-age=86400
  Content-Type: application/xml

/sitemap-index.xml
  Cache-Control: public, max-age=86400
  Content-Type: application/xml

/robots.txt
  Cache-Control: public, max-age=86400

/llms.txt
  Cache-Control: public, max-age=86400
  Content-Type: text/plain; charset=utf-8

/about.txt
  Cache-Control: public, max-age=86400
  Content-Type: text/plain; charset=utf-8
